<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/rootLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/md_theme_background"
    android:fitsSystemWindows="true"
    android:fillViewport="true"
    tools:context=".MainActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tvTitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/app_name"
                android:textSize="34sp"
                android:textColor="@color/md_theme_primary"
                android:textStyle="bold"
                android:fontFamily="sans-serif-medium"
                android:letterSpacing="0.02"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnLanguage"
                style="@style/Widget.Material3.Button.TonalButton"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:text="ES"
                android:textSize="12sp"
                android:textStyle="bold"
                app:cornerRadius="20dp"
                app:icon="@drawable/ic_language"
                app:iconSize="18dp"
                app:iconGravity="textStart"
                app:iconPadding="4dp"/>
        </LinearLayout>

        <TextView
            android:id="@+id/tvSubtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/monitor_mode"
            android:textSize="15sp"
            android:textColor="@color/md_theme_onSurfaceVariant"
            android:layout_marginTop="4dp"/>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardCompatibility"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            app:cardCornerRadius="24dp"
            app:cardBackgroundColor="@color/card_background"
            app:strokeWidth="1dp"
            app:strokeColor="@color/card_stroke"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <ImageView
                        android:id="@+id/ivCompatIcon"
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:src="@drawable/ic_check_circle"
                        app:tint="@color/monitor_active"/>

                    <TextView
                        android:id="@+id/tvCompatTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/device_compatibility"
                        android:textColor="@color/md_theme_onSurface"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:layout_marginStart="12dp"/>

                </LinearLayout>

                <TextView
                    android:id="@+id/tvCompatStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/checking_compatibility"
                    android:textColor="@color/md_theme_onSurfaceVariant"
                    android:textSize="14sp"
                    android:layout_marginTop="8dp"
                    android:layout_marginStart="40dp"/>

                <com.google.android.material.divider.MaterialDivider
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginVertical="16dp"
                    app:dividerColor="@color/card_stroke"/>

                <LinearLayout
                    android:id="@+id/layoutDeviceInfo"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone">

                    <include layout="@layout/item_row_chipset" android:id="@+id/rowChipset"/>
                    <include layout="@layout/item_row_driver" android:id="@+id/rowDriver"/>
                    <include layout="@layout/item_row_root" android:id="@+id/rowRoot"/>
                    <include layout="@layout/item_row_sysfs" android:id="@+id/rowSysfs"/>
                    <include layout="@layout/item_row_capabilities" android:id="@+id/rowCapabilities"/>

                </LinearLayout>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            app:cardCornerRadius="24dp"
            app:cardBackgroundColor="@color/card_background"
            app:strokeWidth="1dp"
            app:strokeColor="@color/card_stroke"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <View
                        android:id="@+id/statusIndicator"
                        android:layout_width="12dp"
                        android:layout_height="12dp"
                        android:background="@drawable/status_indicator"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/wifi_mode"
                        android:textColor="@color/md_theme_onSurfaceVariant"
                        android:textSize="12sp"
                        android:textAllCaps="true"
                        android:letterSpacing="0.1"
                        android:layout_marginStart="12dp"/>
                </LinearLayout>

                <TextView
                    android:id="@+id/tvStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/checking"
                    android:textColor="@color/md_theme_primary"
                    android:textSize="28sp"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif-medium"
                    android:layout_marginTop="12dp"/>

                <com.google.android.material.divider.MaterialDivider
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginVertical="20dp"
                    app:dividerColor="@color/card_stroke"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_wifi"
                        app:tint="@color/md_theme_onSurfaceVariant"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/interface_info"
                        android:textColor="@color/md_theme_onSurfaceVariant"
                        android:textSize="12sp"
                        android:textAllCaps="true"
                        android:letterSpacing="0.1"
                        android:layout_marginStart="12dp"/>
                </LinearLayout>

                <TextView
                    android:id="@+id/tvInfo"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/waiting"
                    android:textColor="@color/md_theme_onSurface"
                    android:textSize="13sp"
                    android:fontFamily="monospace"
                    android:layout_marginTop="12dp"
                    android:lineSpacingExtra="6dp"/>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnToggle"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:layout_marginTop="32dp"
            android:text="@string/enable_monitor"
            android:textColor="@color/md_theme_onPrimary"
            android:textStyle="bold"
            android:textSize="16sp"
            app:cornerRadius="16dp"
            app:backgroundTint="@color/md_theme_primary"
            android:enabled="false"/>

    </LinearLayout>
</ScrollView>
